" Turn on CTRL-<dir> pane toggling.
:nmap <C-h> <C-w>h
:nmap <C-l> <C-w>l
:nmap <C-j> <C-w>j
:nmap <C-k> <C-w>k

" Turn on line numbers
:set number

" Turn on show mode
:set showmode
:set showcmd

" Turn up history
:set history=1000

" Whitespace
:set tabstop=2
:set softtabstop=2

:set smartindent

" -- Custom remaps --
:nmap <C-s> q:/
